# FHIR Server — internal, no auth required
FHIR_SERVER_URL=http://localhost:8000/api/fhir/v1

# BetterAuth / IAM
IAM_JWKS_URL=http://localhost:3000/api/auth/jwks
IAM_ISSUER=http://localhost:3000

# App
ENVIRONMENT=development

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_READ=100
RATE_LIMIT_WRITE=20
RATE_LIMIT_WINDOW=60
