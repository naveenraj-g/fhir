ENVIRONMENT=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
# "db" is the Docker service name — do not change the hostname.
FHIR_DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@db/fhir-server

POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=fhir-server

# ── Redis ─────────────────────────────────────────────────────────────────────
# "redis" is the Docker service name — do not change the hostname.
REDIS_URL=redis://redis:6379

# ── IAM / JWT ─────────────────────────────────────────────────────────────────
# Issuer URL and JWKS endpoint from your identity provider (e.g. Keycloak, Auth0).
IAM_ISSUER=https://your-iam-provider/issuer
IAM_JWKS_URL=https://your-iam-provider/.well-known/jwks.json
